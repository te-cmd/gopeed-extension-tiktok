{
  "name": "tiktok-downloader",
  "author": "Locon213",
  "title": "TikTok Downloader",
  "description": "Download TikTok videos without watermark (HD).",
  "icon": "icon.png",
  "version": "1.0.0",
  "homepage": "https://github.com/Locon213/gopeed-extension-tiktok",
  "repository": {
    "url": "https://github.com/Locon213/gopeed-extension-tiktok"
  },
  "scripts": [
    {
      "event": "onResolve",
      "match": {
        "urls": [
          "*://*.tiktok.com/*",
          "*://*.tiktokv.com/*"
        ]
      },
      "entry": "index.js"
    }
  ],
  "settings": [
    {
      "name": "api_provider",
      "title": "API Provider",
      "description": "Select the service",
      "type": "string",
      "value": "tikwm",
      "options": [
        {
          "label": "TikWM (Best Quality)",
          "value": "tikwm"
        },
        {
          "label": "TikMate (Backup)",
          "value": "tikmate"
        }
      ]
    }
  ]
}